{
  "Tests": [
    {
      "name": "No parameters",
      "param": null,
      "expected": "Usage: {binary_name} [-l] [-d] <path to MIPS executable>\n"
    },
    {
      "name": "Add word",
      "param": "add.exe",
      "expected": "102"
    },
    {
      "name": "Hello World",
      "param": "hello_world.exe",
      "expected": "Hello World!\n"
    },
    {
      "name": "Load upper immediate",
      "param": "lui.exe",
      "expected": "65536"
    },
    {
      "name": "Substract word",
      "param": "sub.exe",
      "expected": "-30"
    },
    {
      "name": "Add unsigned word",
      "param": "addu.exe",
      "expected": "102"
    }
  ]
}
