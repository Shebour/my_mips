    {
      "name": "Debugger: print / step / break",
      "param": "test/add.exe",
      "flags": "-d",
      "input": "print 0x0\nstep\nstep\nbreak 0x100\nexit\n",
      "expected_stdout": "0x00000000: 0x0c000040: jal 0x100\nExecuting pc = 0x00000000: 0x0c000040: jal 0x100\nExecuting pc = 0x00000004: 0x00000000: nop\nBreakpoint set at 0x00000100\n",
      "expected_stderr": ""
    },
    {
      "name": "Debugger: breakpoint + continue",
      "param": "test/add.exe",
      "flags": "-d",
      "input": "break 0x100\ncontinue\nexit\n",
      "expected_stdout": "Breakpoint set at 0x00000100\nExecuting pc = 0x00000000: 0x0c000040: jal 0x100\nExecuting pc = 0x00000004: 0x00000000: nop\nBreakpoint at 0x00000100\n",
      "expected_stderr": ""
    },
    {
      "name": "Debugger: memory / delete / list / unknown",
      "param": "test/add.exe",
      "flags": "-d",
      "input": "memory 0x4 2\ndelete 0x50\nbreakpoints\nbadcmd\nexit\n",
      "expected_stdout": "0x00000004: 0x00000000\n0x00000008: 0x3402000a\nNo breakpoint at 0x00000050\nNo breakpoints\nUnknown command: badcmd (try 'help')\n",
      "expected_stderr": ""
